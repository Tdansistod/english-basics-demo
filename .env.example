# Copy this file to `.env` before running the server.
# MiniMax is OpenAI-compatible. Get a key from https://platform.minimax.io/
MINIMAX_API_KEY=your_key_here

# Optional overrides (defaults shown)
# MINIMAX_BASE_URL=https://api.minimax.io/v1
# MINIMAX_MODEL=MiniMax-M3              # used for session report (long synthesis)
# MINIMAX_FAST_MODEL=MiniMax-M2.5-highspeed  # used for free-write checks (short turns)

# Optional: override the port (defaults to 3002)
# PORT=3002
